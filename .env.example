# ============================================================================
# DATABASE — CHANGE CREDENTIALS BEFORE DEPLOYING
# ============================================================================
# Generate a strong password: python -c "import secrets; print(secrets.token_urlsafe(24))"
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/accounting
APP_ENV=dev

# ============================================================================
# CORS — restrict in production (comma-separated origins)
# ============================================================================
APP_CORS_ORIGINS=http://localhost:8000

# ============================================================================
# AUTH SECRET — REQUIRED in production
# ============================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# In dev mode, a random secret is auto-generated if not set (sessions won't survive restarts).
AUTH_SECRET=

# ============================================================================
# AI PROVIDER
# ============================================================================
AI_PROVIDER=lmstudio
# Generic OpenAI-compatible backend (MetisAI, OpenAI, etc.)
AI_BASE_URL=
AI_MODEL=
AI_API_KEY=
AI_API_KEY_HEADER=Authorization
AI_API_KEY_PREFIX=Bearer

# MetisAI
METIS_BASE_URL=https://api.metisai.ir/openai/v1
METIS_MODEL=gpt-4o-mini
METIS_API_KEY=

# Local AI (LM Studio)
# From Docker: use http://host.docker.internal:1234
# Without Docker: use http://localhost:1234 or your machine's IP
LM_STUDIO_BASE_URL=http://host.docker.internal:1234
LM_STUDIO_MODEL=qwen/qwen3-4b-thinking-2507

# ============================================================================
# NOTIFICATIONS (optional)
# ============================================================================
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TO=
