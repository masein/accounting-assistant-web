# Copy to `.env` on the server and fill in. Used by docker-compose.prod.yml.

# --- Required ---
# Session-signing secret. Generate with: openssl rand -hex 32
AUTH_SECRET=
# Postgres password for the bundled db service.
DB_PASSWORD=change-me-strong

# --- Image / networking ---
# Pin a specific published tag for reproducible deploys, e.g.
#   docker.netixsystem.com/accounting-assistant-api:1.2.3
# Keep :latest for zero-touch auto-updates via Watchtower.
API_IMAGE=docker.netixsystem.com/accounting-assistant-api:latest
API_PORT=8000
APP_ENV=prod
# How often (seconds) Watchtower checks the registry for a new image.
WATCHTOWER_POLL_INTERVAL=120
# Comma-separated origins allowed by CORS (set to your public URL).
APP_CORS_ORIGINS=http://localhost:8000

# --- AI provider (Metis is the default; needs a key) ---
AI_PROVIDER=metis
METIS_API_KEY=
METIS_BASE_URL=https://api.metisai.ir/openai/v1
METIS_MODEL=gpt-4o-mini

# --- Optional: Anthropic (Claude) via Metis passthrough ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.metisai.ir/anthropic
# ANTHROPIC_MODEL=claude-opus-4-6

# --- Optional: local LM Studio instead of Metis ---
# AI_PROVIDER=lmstudio
# LM_STUDIO_BASE_URL=http://host.docker.internal:1234
